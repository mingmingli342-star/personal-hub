generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ==================== 资产管理 ====================

model Account {
  id        String        @id @default(uuid())
  name      String
  type      String        // bank | alipay | wechat | cash | other
  balance   Float         @default(0)
  color     String        @default("#3b82f6")
  icon      String        @default("wallet")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  transactions Transaction[]
}

model Transaction {
  id          String    @id @default(uuid())
  amount      Float
  type        String    // income | expense
  category    String    // 餐饮/交通/购物/薪资/投资/房租/娱乐/医疗/教育/其他
  description String    @default("")
  date        DateTime  @default(now())
  accountId   String
  account     Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Budget {
  id        String   @id @default(uuid())
  category  String
  amount    Float
  period    String   // monthly | yearly
  startDate DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== 工作管理 ====================

model Project {
  id          String    @id @default(uuid())
  name        String
  description String    @default("")
  status      String    @default("active") // active | completed | paused
  color       String    @default("#3b82f6")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tasks       Task[]
  workLogs    WorkLog[]
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String    @default("")
  status      String    @default("todo") // todo | in_progress | done
  priority    String    @default("medium") // high | medium | low
  dueDate     DateTime?
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  estimatedMinutes Int? @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workLogs    WorkLog[]
}

model WorkLog {
  id        String   @id @default(uuid())
  content   String
  date      DateTime @default(now())
  durationMinutes Int @default(0)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==================== 身体与运动 ====================

model BodyRecord {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  weight    Float?   // kg
  bodyFat   Float?   // 体脂率 %
  bmi       Float?
  waist     Float?   // 腰围 cm
  note      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExerciseRecord {
  id              String   @id @default(uuid())
  date            DateTime @default(now())
  type            String   // running | swimming | cycling | gym | yoga | walking | basketball | football | tennis | other
  durationMinutes Int      @default(0)
  calories        Float?   // 消耗卡路里
  intensity       String   @default("medium") // low | medium | high
  note            String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==================== 规划管理 ====================

model Goal {
  id          String   @id @default(uuid())
  title       String
  description String   @default("")
  category    String   @default("personal") // personal | career | health | finance | learning | other
  startDate   DateTime @default(now())
  targetDate  DateTime?
  progress    Float    @default(0) // 0-100
  status      String   @default("active") // active | completed | paused
  color       String   @default("#3b82f6")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Habit {
  id          String     @id @default(uuid())
  name        String
  description String     @default("")
  frequency   String     @default("daily") // daily | weekly | monthly
  targetCount Int        @default(1) // 目标次数（每周3次等）
  color       String     @default("#22c55e")
  icon        String     @default("check")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  logs        HabitLog[]
}

model HabitLog {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  completed Boolean  @default(true)
  note      String   @default("")
  createdAt DateTime @default(now())
}

model CalendarEvent {
  id        String   @id @default(uuid())
  title     String
  startTime DateTime
  endTime   DateTime
  allDay    Boolean  @default(false)
  color     String   @default("#3b82f6")
  note      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
